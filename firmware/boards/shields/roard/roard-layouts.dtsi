#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        kscan = <&kscan>;
        transform = <&default_transform>;

        keys = <
            /* Row 0 (12 keys) */
            &key_physical_attrs 100 100 50   38   0     0    0      /* ESC */
            &key_physical_attrs 100 100 150  38   0     0    0      /* 1 */
            &key_physical_attrs 100 100 250  13   0     0    0      /* 2 */
            &key_physical_attrs 100 100 350  0    0     0    0      /* 3 */
            &key_physical_attrs 100 100 450  13   0     0    0      /* 4 */
            &key_physical_attrs 100 100 550  25   0     0    0      /* 5 */
            &key_physical_attrs 100 100 1300 25   0     0    0      /* 6 */
            &key_physical_attrs 100 100 1400 13   0     0    0      /* 7 */
            &key_physical_attrs 100 100 1500 0    0     0    0      /* 8 */
            &key_physical_attrs 100 100 1600 13   0     0    0      /* 9 */
            &key_physical_attrs 100 100 1700 38   0     0    0      /* 0 */
            &key_physical_attrs 100 100 1800 38   0     0    0      /* = */

            /* Row 1 (12 keys) */
            &key_physical_attrs 100 100 50   138  0     0    0      /* ` */
            &key_physical_attrs 100 100 150  138  0     0    0      /* Q */
            &key_physical_attrs 100 100 250  113  0     0    0      /* W */
            &key_physical_attrs 100 100 350  100  0     0    0      /* E */
            &key_physical_attrs 100 100 450  113  0     0    0      /* R */
            &key_physical_attrs 100 100 550  125  0     0    0      /* T */
            &key_physical_attrs 100 100 1300 125  0     0    0      /* Y */
            &key_physical_attrs 100 100 1400 113  0     0    0      /* U */
            &key_physical_attrs 100 100 1500 100  0     0    0      /* I */
            &key_physical_attrs 100 100 1600 113  0     0    0      /* O */
            &key_physical_attrs 100 100 1700 138  0     0    0      /* P */
            &key_physical_attrs 100 100 1800 138  0     0    0      /* \ */

            /* Row 2 (12 keys) */
            &key_physical_attrs 100 100 50   238  0     0    0      /* TAB */
            &key_physical_attrs 100 100 150  238  0     0    0      /* A */
            &key_physical_attrs 100 100 250  213  0     0    0      /* S */
            &key_physical_attrs 100 100 350  200  0     0    0      /* D */
            &key_physical_attrs 100 100 450  213  0     0    0      /* F */
            &key_physical_attrs 100 100 550  225  0     0    0      /* G */
            &key_physical_attrs 100 100 1300 225  0     0    0      /* H */
            &key_physical_attrs 100 100 1400 213  0     0    0      /* J */
            &key_physical_attrs 100 100 1500 200  0     0    0      /* K */
            &key_physical_attrs 100 100 1600 213  0     0    0      /* L */
            &key_physical_attrs 100 100 1700 238  0     0    0      /* ; */
            &key_physical_attrs 100 100 1800 238  0     0    0      /* ' */

            /* Row 3 (14 keys) */
            &key_physical_attrs 100 100 50   338  0     0    0      /* LSHFT */
            &key_physical_attrs 100 100 150  338  0     0    0      /* Z */
            &key_physical_attrs 100 100 250  313  0     0    0      /* X */
            &key_physical_attrs 100 100 350  300  0     0    0      /* C */
            &key_physical_attrs 100 100 450  313  0     0    0      /* V */
            &key_physical_attrs 100 100 550  325  0     0    0      /* B */
            &key_physical_attrs 100 100 650  325  0     0    0      /* FN */
            &key_physical_attrs 100 100 1200 325  0     0    0      /* - */
            &key_physical_attrs 100 100 1300 325  0     0    0      /* N */
            &key_physical_attrs 100 100 1400 313  0     0    0      /* M */
            &key_physical_attrs 100 100 1500 300  0     0    0      /* , */
            &key_physical_attrs 100 100 1600 313  0     0    0      /* . */
            &key_physical_attrs 100 100 1700 338  0     0    0      /* / */
            &key_physical_attrs 100 100 1800 338  0     0    0      /* RSHFT */

            /* Row 4 (8 keys - Left mods, Left thumb cluster, Right upper arrows) */
            &key_physical_attrs 100 100 50   438  0       0    0      /* LCTRL */
            &key_physical_attrs 100 100 218  256  (-3800) 600  375    /* LALT */
            &key_physical_attrs 100 100 320  307  (-2800) 600  375    /* LGUI */
            &key_physical_attrs 100 150 476  443  1000    600  375    /* RET */
            &key_physical_attrs 100 150 593  436  1500    600  375    /* BSPC (Left) */
            &key_physical_attrs 100 150 693  432  1500    600  375    /* LBKT */
            &key_physical_attrs 100 100 1600 413  0       0    0      /* UP */
            &key_physical_attrs 100 100 1800 438  0       0    0      /* DEL */

            /* Row 5 (6 keys - Right thumb cluster, Right lower arrows) */
            &key_physical_attrs 100 150 1107 449  (-1500) 1375 375    /* RBKT */
            &key_physical_attrs 100 150 1225 460  (-1000) 1375 375    /* BSPC (Right) */
            &key_physical_attrs 100 150 1340 463  (-700)  1375 375    /* SPACE */
            &key_physical_attrs 100 100 1500 513  0       0    0      /* LEFT */
            &key_physical_attrs 100 100 1600 513  0       0    0      /* DOWN */
            &key_physical_attrs 100 100 1700 513  0       0    0      /* RIGHT */
        >;
    };
};

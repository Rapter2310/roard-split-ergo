if SHIELD_ROARD_DONGLE

config ZMK_KEYBOARD_NAME
    default "roard"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT
    default y

config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 2

config ZMK_STUDIO
    default y

endif # SHIELD_ROARD_DONGLE

if SHIELD_ROARD_LEFT || SHIELD_ROARD_RIGHT

config ZMK_SPLIT
    default y

endif # SHIELD_ROARD_LEFT || SHIELD_ROARD_RIGHT
